# ── chobo CRM 配置(接入方填;cp 为 chobo-crm.env) ──

# 接入方自己的 postgres 连接串(必填)。空库即可:CRM 启动自动建表 + 灌价目表。
# 例:postgres://chobo:strongpass@10.0.0.5:5432/chobo
#   - 库可空,但要先存在(CREATE DATABASE chobo;)。
#   - postgres 与 CRM 同机时,容器内连宿主用 host.docker.internal(Linux 需 extra_hosts,
#     或直接用宿主局域网 IP)。
CHOBO_DATABASE_URL=postgres://USER:PASS@HOST:5432/chobo

# ingest 鉴权 secret(必填,自定一个强随机串)。
# 接入方业务服务的 CHOBO_INGEST_SECRET 必须与此 *完全相同*,否则上报 401 被拒。
CHOBO_INGEST_SECRET=CHANGE-ME-to-a-strong-random-secret

# (可选)请求 payload 落库模式:off | metadata | truncated(默认 metadata)。
# CHOBO_PAYLOAD_MODE=metadata

# (可选)价目热载轮询间隔(秒),默认 60;0=关闭(改价需重启容器)。
# CHOBO_PRICE_REFRESH_SEC=60
