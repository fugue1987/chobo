{
  "name": "@chobo/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch --import tsx src/server.ts",
    "start": "node dist/server.js",
    "reprice": "node dist/reprice-cli.js",
    "seed:prices": "node dist/seed-cli.js",
    "test": "vitest run",
    "seed:events": "node --import tsx scripts/seed-events-cli.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "fastify": "5.8.5",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.3",
    "@types/node": "^20.0.0",
    "testcontainers": "^12.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.0"
  }
}
