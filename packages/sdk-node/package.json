{
  "name": "@chobo/sdk",
  "version": "0.1.5",
  "description": "chobo — low-intrusion LLM usage metering SDK (Node/TypeScript)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate": "publint && attw --pack"
  },
  "dependencies": {},
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@types/node": "^22.0.0",
    "ajv": "^8.17.0",
    "publint": "^0.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.0"
  }
}
